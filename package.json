{
	"private": true,
	"type": "module",
	"version": "1.0.0",
	"name": "angular-21",
	"packageManager": "npm@11.11.1",
	"engines": {
		"npm": ">=11.11.1",
		"node": ">=24.14.0"
	},
	"overrides": {
		"vite": "^7.3.2"
	},
	"scripts": {
		"ng": "ng",
		"test": "ng test",
		"lint": "ng lint",
		"prepare": "husky",
		"start": "ng serve",
		"build": "ng build",
		"start:server": "node server.js",
		"build:staging": "ng build --configuration=staging",
		"watch": "ng build --watch --configuration=development",
		"format": "prettier --write **/*.{ts,js,css,json,html}",
		"build:production": "ng build --configuration=production",
		"build:development": "ng build --configuration=development"
	},
	"dependencies": {
		"@angular/cdk": "^21.2.5",
		"@angular/common": "^21.2.5",
		"@angular/compiler": "^21.2.5",
		"@angular/core": "^21.2.5",
		"@angular/forms": "^21.2.5",
		"@angular/platform-browser": "^21.2.5",
		"@angular/router": "^21.2.5",
		"@ngrx/signals": "^21.1.0",
		"@primeuix/themes": "^2.0.3",
		"crypto-es": "^3.1.3",
		"http-status-codes": "^2.3.0",
		"javascript-time-ago": "^2.6.4",
		"lodash-es": "^4.17.23",
		"lucide-angular": "^1.0.0",
		"luxon": "^3.7.2",
		"ngx-cookie-service": "^21.3.1",
		"ngx-mask": "^21.0.1",
		"ngx-progressbar": "^14.0.0",
		"ngx-scrollbar": "^19.1.4",
		"ngx-sonner": "^3.1.0",
		"primeicons": "^7.0.0",
		"primeng": "^21.1.4",
		"rxjs": "^7.8.2",
		"tslib": "^2.8.1",
		"webfontloader": "^1.6.28",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@angular/build": "^21.2.6",
		"@angular/cli": "^21.2.6",
		"@angular/compiler-cli": "^21.2.5",
		"@types/lodash-es": "^4.17.12",
		"@types/luxon": "^3.7.1",
		"@types/node": "^24.12.0",
		"@types/webfontloader": "^1.6.38",
		"@typescript-eslint/eslint-plugin": "^8.58.0",
		"angular-eslint": "^21.3.1",
		"eslint": "^9.39.4",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-import": "^2.32.0",
		"eslint-plugin-jsdoc": "^62.8.1",
		"eslint-plugin-prettier": "^5.5.5",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"jsdom": "^29.0.1",
		"lint-staged": "^16.4.0",
		"prettier": "^3.8.1",
		"typescript": "~5.9.2",
		"typescript-eslint": "^8.58.0",
		"vitest": "^4.0.8"
	},
	"lint-staged": {
		"*.{css,scss,json,md,js}": "prettier --write",
		"*.{ts,html}": [
			"eslint --fix",
			"prettier --write"
		]
	}
}
