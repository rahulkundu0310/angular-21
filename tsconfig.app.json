/**
 * Defines TypeScript properties by extending base defaults and establishing compiling parameters for production bundling.
 * Processes references with output directories and file inclusions to maintain uniform lifecycles within the application.
 *
 * @since 01 December 2025
 * @author Rahul Kundu
 */
{
	"extends": "./tsconfig.json",
	"compilerOptions": {
		"types": ["node"],
		"outDir": "./out-tsc/app"
	},
	"exclude": ["src/**/*.spec.ts"],
	"include": ["src/**/*.ts", "src/**/*.d.ts"]
}
